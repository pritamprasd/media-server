FLASK_ENV=development
SECRET_KEY=change-me-in-production
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/media_server
CORS_ORIGINS=http://localhost:5173
PORT=5000
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava
# Celery queue names (must match docker-compose worker -Q flags)
CELERY_QUEUE_IMPORT=import_queue
CELERY_QUEUE_METADATA=metadata
CELERY_QUEUE_AI=ai_metadata
CELERY_QUEUE_THUMBNAIL=thumbnail
CELERY_QUEUE_FACE=face_queue
# Constants
IMPORT_DEFAULT_PATH="/"


FACE_MATCH_THRESHOLD=0.4
# Number of images to process per face-detection batch (reuses model across images)
FACE_BATCH_SIZE=10