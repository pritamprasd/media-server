{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "5.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" }
  ],
  "title": "Media Server",
  "uid": "media-server",
  "version": 2,
  "timezone": "browser",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "tags": ["media-server", "prometheus", "provisioned"],
  "schemaVersion": 39,
  "style": "dark",
  "panels": [
    {
      "title": "HTTP Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{}[$__rate_interval]))",
          "legendFormat": "All"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..\"}[$__rate_interval]))",
          "legendFormat": "4xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "custom": { "displayMode": "table" },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Request Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "title": "Active Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "sum(http_requests_in_flight{})",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 4,
      "title": "Top Endpoints by Rate",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "topk(10, sum(rate(http_requests_total{}[$__rate_interval])) by (endpoint))",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": {}, "indexByName": {}, "renameByName": { "Value": "Rate" } } }
      ],
      "fieldConfig": {
        "defaults": { "unit": "rps" }
      }
    },
    {
      "title": "Celery Tasks",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "title": "Task Rate by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "topk(10, sum(rate(celery_tasks_total{state=\"success\"}[$__rate_interval])) by (task))",
          "legendFormat": "{{task}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "id": 6,
      "title": "Task Duration (p50/p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 10 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(celery_task_duration_seconds_bucket{}[$__rate_interval])) by (le,task))",
          "legendFormat": "p95 {{task}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(celery_task_duration_seconds_bucket{}[$__rate_interval])) by (le,task))",
          "legendFormat": "p50 {{task}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "title": "Task Success vs Failure",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 10 },
      "targets": [
        {
          "expr": "sum(rate(celery_tasks_total{state=\"success\"}[$__rate_interval]))",
          "legendFormat": "Success"
        },
        {
          "expr": "sum(rate(celery_tasks_total{state=\"failure\"}[$__rate_interval]))",
          "legendFormat": "Failure"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "id": 8,
      "title": "Task Retry Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 10 },
      "targets": [
        {
          "expr": "sum(rate(celery_task_retries_total{}[$__rate_interval])) by (task)",
          "legendFormat": "{{task}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "title": "File Operations",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "title": "File Import / Delete Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 19 },
      "targets": [
        {
          "expr": "rate(files_imported_total{}[$__rate_interval])",
          "legendFormat": "Imports"
        },
        {
          "expr": "rate(files_deleted_total{}[$__rate_interval])",
          "legendFormat": "Deletes"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "id": 10,
      "title": "File Serve / Download Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 19 },
      "targets": [
        {
          "expr": "rate(files_served_total{}[$__rate_interval])",
          "legendFormat": "Serves"
        },
        {
          "expr": "rate(files_downloaded_total{}[$__rate_interval])",
          "legendFormat": "Downloads"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "id": 11,
      "title": "File Edit Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 19 },
      "targets": [
        {
          "expr": "rate(files_edited_total{}[$__rate_interval])",
          "legendFormat": "Edits"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "id": 12,
      "title": "File Export Rate by Format",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 19 },
      "targets": [
        {
          "expr": "sum(rate(files_exported_total{}[$__rate_interval])) by (format)",
          "legendFormat": "{{format}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "title": "Uploads",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 13,
      "title": "Upload Rate (Files)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "rate(uploads_total{}[$__rate_interval])",
          "legendFormat": "Files/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "id": 14,
      "title": "Upload Rate (Bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 28 },
      "targets": [
        {
          "expr": "rate(upload_bytes_total{}[$__rate_interval])",
          "legendFormat": "Bytes/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 15,
      "title": "Explorer Operations Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "sum(rate(explorer_operations_total{}[$__rate_interval])) by (operation)",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "id": 16,
      "title": "Geocode Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 28 },
      "targets": [
        {
          "expr": "rate(geocode_requests_total{cache=\"hit\"}[$__rate_interval])",
          "legendFormat": "Cache Hit"
        },
        {
          "expr": "rate(geocode_requests_total{cache=\"miss\"}[$__rate_interval])",
          "legendFormat": "Cache Miss"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "title": "Processing Pipeline",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 17,
      "title": "Metadata Extraction Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 37 },
      "targets": [
        {
          "expr": "rate(metadata_extracted_total{}[$__rate_interval])",
          "legendFormat": "Extracted"
        },
        {
          "expr": "rate(metadata_failed_total{}[$__rate_interval])",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "id": 18,
      "title": "Thumbnail Generation Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 37 },
      "targets": [
        {
          "expr": "rate(thumbnails_generated_total{}[$__rate_interval])",
          "legendFormat": "Thumbnails"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "id": 19,
      "title": "AI Description Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 37 },
      "targets": [
        {
          "expr": "rate(ai_descriptions_total{}[$__rate_interval])",
          "legendFormat": "Success"
        },
        {
          "expr": "rate(ai_failed_total{}[$__rate_interval])",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "id": 20,
      "title": "Face Detection Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 37 },
      "targets": [
        {
          "expr": "rate(faces_detected_total{}[$__rate_interval])",
          "legendFormat": "Faces"
        },
        {
          "expr": "rate(persons_created_total{}[$__rate_interval])",
          "legendFormat": "New Persons"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "title": "Pending Processing",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "title": "Unprocessed Files by Step",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 },
      "targets": [
        {
          "expr": "unprocessed_files_total{step=\"metadata\"}",
          "legendFormat": "Metadata"
        },
        {
          "expr": "unprocessed_files_total{step=\"thumbnail\"}",
          "legendFormat": "Thumbnail"
        },
        {
          "expr": "unprocessed_files_total{step=\"face_detection\"}",
          "legendFormat": "Face Detection"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "continuous-GrYlRd" },
          "custom": { "displayMode": "gradient" },
          "min": 0
        }
      }
    },
    {
      "id": 22,
      "title": "Files by MIME Category",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 46 },
      "targets": [
        {
          "expr": "files_by_mime_category{category=\"image\"}",
          "legendFormat": "Image"
        },
        {
          "expr": "files_by_mime_category{category=\"video\"}",
          "legendFormat": "Video"
        },
        {
          "expr": "files_by_mime_category{category=\"audio\"}",
          "legendFormat": "Audio"
        },
        {
          "expr": "files_by_mime_category{category=\"document\"}",
          "legendFormat": "Document"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "displayMode": "gradient" },
          "min": 0
        }
      }
    },
    {
      "title": "Library Statistics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 23,
      "title": "Total Files",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 0, "y": 55 },
      "targets": [
        {
          "expr": "library_files_total{status=\"active\"}",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "id": 24,
      "title": "Deleted Files",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 3, "y": 55 },
      "targets": [
        {
          "expr": "library_files_total{status=\"deleted\"}",
          "legendFormat": "Deleted"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      }
    },
    {
      "id": 25,
      "title": "Library Size",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 6, "y": 55 },
      "targets": [
        {
          "expr": "library_size_bytes{}",
          "legendFormat": "Size"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 26,
      "title": "Total Sessions",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 9, "y": 55 },
      "targets": [
        {
          "expr": "library_sessions_total{}",
          "legendFormat": "Sessions"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 27,
      "title": "Total Tags",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 12, "y": 55 },
      "targets": [
        {
          "expr": "tags_total{}",
          "legendFormat": "Tags"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 28,
      "title": "Tagged Files",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 15, "y": 55 },
      "targets": [
        {
          "expr": "tagged_files_total{}",
          "legendFormat": "Files"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 29,
      "title": "Persons",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 18, "y": 55 },
      "targets": [
        {
          "expr": "persons_total{}",
          "legendFormat": "Persons"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 30,
      "title": "Detected Faces",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 21, "y": 55 },
      "targets": [
        {
          "expr": "detected_faces_total{}",
          "legendFormat": "Faces"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Face Processing",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 61 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "title": "Face Detection Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 62 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(face_detection_duration_seconds_bucket{}[$__rate_interval])) by (le,queue))",
          "legendFormat": "p95 {{queue}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(face_detection_duration_seconds_bucket{}[$__rate_interval])) by (le,queue))",
          "legendFormat": "p50 {{queue}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 32,
      "title": "Face Scans Queued",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 62 },
      "targets": [
        {
          "expr": "rate(face_scans_total{}[$__rate_interval])",
          "legendFormat": "Scan Ops"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "id": 33,
      "title": "Persons Created Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 62 },
      "targets": [
        {
          "expr": "rate(persons_created_total{}[$__rate_interval])",
          "legendFormat": "New Persons"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "title": "Process Resources",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 70 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 34,
      "title": "Memory Usage (Resident)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 71 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=~\"media.*\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 35,
      "title": "Virtual Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 71 },
      "targets": [
        {
          "expr": "process_virtual_memory_bytes{job=~\"media.*\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 36,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 79 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=~\"media.*\"}[$__rate_interval])",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "id": 37,
      "title": "Open FDs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 79 },
      "targets": [
        {
          "expr": "process_open_fds{job=~\"media.*\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
