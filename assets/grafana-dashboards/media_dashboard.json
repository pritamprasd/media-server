          "expr": "label_replace(histogram_quantile(0.999, sum(rate(face_detection_duration_seconds_bucket{}[$__rate_interval])) by (le,queue)), \"quantile_filter\", \"p999\", \"\", \"\") and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p999\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p999 {{queue}}"
        },
        {
          "expr": "label_replace(histogram_quantile(0.99, sum(rate(face_detection_duration_seconds_bucket{}[$__rate_interval])) by (le,queue)), \"quantile_filter\", \"p99\", \"\", \"\") and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p99\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
