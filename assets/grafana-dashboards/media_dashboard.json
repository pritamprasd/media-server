{
  "__inputs": [],
  "__requires": [],
  "title": "Media Dashboard",
  "uid": "media-dashboard",
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "tags": ["media-server", "prometheus"],
  "schemaVersion": 39,
  "style": "dark",
  "templating": {
    "list": [
      {
        "name": "endpoint",
        "type": "query",
        "query": "label_values(http_requests_total, endpoint)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "datasource": "Prometheus",
        "definition": "label_values(http_requests_total, endpoint)"
      },
      {
        "name": "method",
        "type": "query",
        "query": "label_values(http_requests_total{endpoint=~\"$endpoint\"}, method)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "datasource": "Prometheus",
        "definition": "label_values(http_requests_total{endpoint=~\"$endpoint\"}, method)"
      },
      {
        "name": "quantile",
        "type": "custom",
        "query": "p50,p95,p99,p999",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "title": "System Summary",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Total Files",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "max(sum(library_files_total{}) by (status))",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "title": "Active Files",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "targets": [
        {
          "expr": "max(library_files_total{status=\"active\"})",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "title": "Library Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "max(library_size_bytes{})",
          "legendFormat": "Size"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Total Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "targets": [
        {
          "expr": "max(library_sessions_total{})",
          "legendFormat": "Sessions"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Total Tags",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "max(tags_total{})",
          "legendFormat": "Tags"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Persons",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "targets": [
        {
          "expr": "max(persons_total{})",
          "legendFormat": "Persons"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Detected Faces",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "max(detected_faces_total{})",
          "legendFormat": "Faces"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "DB Pool Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "targets": [
        {
          "expr": "max(db_connection_pool_size{})",
          "legendFormat": "Pool"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "green", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "title": "HTTP Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "targets": [
        {
          "expr": "topk(8, sum(rate(http_requests_total{}[$__rate_interval])) by (endpoint))",
          "legendFormat": "{{endpoint}}"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx Total"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..\"}[$__rate_interval]))",
          "legendFormat": "4xx Total"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["last", "max", "mean"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "custom": { "displayMode": "table" }
        }
      }
    },
    {
      "title": "Response Time by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "targets": [
        {
          "expr": "topk(8, label_replace(histogram_quantile(0.999, sum(rate(http_request_duration_seconds_bucket{}[$__rate_interval])) by (le, endpoint)), \"quantile_filter\", \"p999\", \"\", \"\")) and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p999\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p999 {{endpoint}}"
        },
        {
          "expr": "topk(8, label_replace(histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{}[$__rate_interval])) by (le, endpoint)), \"quantile_filter\", \"p99\", \"\", \"\")) and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p99\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p99 {{endpoint}}"
        },
        {
          "expr": "topk(8, label_replace(histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{}[$__rate_interval])) by (le, endpoint)), \"quantile_filter\", \"p95\", \"\", \"\")) and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p95\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p95 {{endpoint}}"
        },
        {
          "expr": "label_replace(histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{}[$__rate_interval])) by (le)), \"quantile_filter\", \"p50\", \"\", \"\") and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p50\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p50 Overall"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["last", "max", "mean"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Active Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "sum(http_requests_in_flight{})",
          "legendFormat": "Active"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {}
    },
    {
      "title": "Endpoint & Method Stats",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        {
          "expr": "topk(20, sum(rate(http_requests_total{}[$__rate_interval])) by (method, endpoint))",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": {}, "indexByName": {}, "renameByName": { "method": "Method", "endpoint": "Endpoint", "Value": "Rate" } } }
      ],
      "fieldConfig": {
        "defaults": { "unit": "rps" }
      }
    },
    {
      "title": "API Endpoint Details",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Request Rate by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{endpoint=~\"$endpoint\", method=~\"$method\"}[$__rate_interval])) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["last", "max", "mean"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": { "unit": "rps" }
      }
    },
    {
      "title": "Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "targets": [
        {
          "expr": "label_replace(histogram_quantile(0.999, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"$endpoint\", method=~\"$method\"}[$__rate_interval])) by (le)), \"quantile_filter\", \"p999\", \"\", \"\") and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p999\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p999"
        },
        {
          "expr": "label_replace(histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"$endpoint\", method=~\"$method\"}[$__rate_interval])) by (le)), \"quantile_filter\", \"p99\", \"\", \"\") and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p99\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p99"
        },
        {
          "expr": "label_replace(histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"$endpoint\", method=~\"$method\"}[$__rate_interval])) by (le)), \"quantile_filter\", \"p95\", \"\", \"\") and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p95\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p95"
        },
        {
          "expr": "label_replace(histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"$endpoint\", method=~\"$method\"}[$__rate_interval])) by (le)), \"quantile_filter\", \"p50\", \"\", \"\") and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p50\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p50"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["last", "max", "mean"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Status Code Distribution",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "targets": [
        {
          "expr": "topk(10, sum(rate(http_requests_total{endpoint=~\"$endpoint\", method=~\"$method\"}[$__rate_interval])) by (status))",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": {}, "indexByName": {}, "renameByName": { "status": "Status", "Value": "Rate" } } }
      ],
      "fieldConfig": {
        "defaults": { "unit": "rps" }
      }
    },
    {
      "title": "API Summary",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{endpoint=~\"$endpoint\", method=~\"$method\"}[$__rate_interval]))",
          "legendFormat": "Total Rate"
        },
        {
          "expr": "sum(rate(http_requests_total{endpoint=~\"$endpoint\", method=~\"$method\", status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "Error Rate"
        },
        {
          "expr": "sum(rate(http_requests_total{endpoint=~\"$endpoint\", method=~\"$method\", status=~\"2..\"}[$__rate_interval]))",
          "legendFormat": "Success Rate"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"$endpoint\", method=~\"$method\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95 Latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Celery Tasks",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Task Rate by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "targets": [
        {
          "expr": "topk(10, sum(rate(celery_tasks_total{state=\"success\"}[$__rate_interval])) by (task))",
          "legendFormat": "{{task}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["last", "max", "mean"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "title": "Task Duration (p50/p95/p99/p999)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "targets": [
        {
          "expr": "topk(5, label_replace(histogram_quantile(0.999, sum(rate(celery_task_duration_seconds_bucket{}[$__rate_interval])) by (le,task)), \"quantile_filter\", \"p999\", \"\", \"\")) and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p999\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p999 {{task}}"
        },
        {
          "expr": "topk(5, label_replace(histogram_quantile(0.99, sum(rate(celery_task_duration_seconds_bucket{}[$__rate_interval])) by (le,task)), \"quantile_filter\", \"p99\", \"\", \"\")) and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p99\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p99 {{task}}"
        },
        {
          "expr": "topk(5, label_replace(histogram_quantile(0.95, sum(rate(celery_task_duration_seconds_bucket{}[$__rate_interval])) by (le,task)), \"quantile_filter\", \"p95\", \"\", \"\")) and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p95\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p95 {{task}}"
        },
        {
          "expr": "label_replace(histogram_quantile(0.50, sum(rate(celery_task_duration_seconds_bucket{}[$__rate_interval])) by (le)), \"quantile_filter\", \"p50\", \"\", \"\") and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p50\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p50 Overall"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["last", "max", "mean"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Active Tasks by Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
      "targets": [
        {
          "expr": "sum(celery_active_tasks{}) by (queue)",
          "legendFormat": "{{queue}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["last", "max", "mean"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Task Outcomes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 51 },
      "targets": [
        {
          "expr": "sum(rate(celery_tasks_total{state=\"success\"}[$__rate_interval]))",
          "legendFormat": "Success"
        },
        {
          "expr": "sum(rate(celery_tasks_total{state=\"failure\"}[$__rate_interval]))",
          "legendFormat": "Failure"
        },
        {
          "expr": "sum(rate(celery_task_retries_total{}[$__rate_interval]))",
          "legendFormat": "Retries"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["last", "max", "mean"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "title": "Task Retry Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 59 },
      "targets": [
        {
          "expr": "sum(rate(celery_task_retries_total{}[$__rate_interval])) by (task)",
          "legendFormat": "{{task}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["last", "max", "mean"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "title": "Task Duration by Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 59 },
      "targets": [
        {
          "expr": "label_replace(histogram_quantile(0.999, sum(rate(celery_task_duration_seconds_bucket{}[$__rate_interval])) by (le,queue)), \"quantile_filter\", \"p999\", \"\", \"\") and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p999\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p999 {{queue}}"
        },
        {
          "expr": "label_replace(histogram_quantile(0.99, sum(rate(celery_task_duration_seconds_bucket{}[$__rate_interval])) by (le,queue)), \"quantile_filter\", \"p99\", \"\", \"\") and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p99\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p99 {{queue}}"
        },
        {
          "expr": "label_replace(histogram_quantile(0.95, sum(rate(celery_task_duration_seconds_bucket{}[$__rate_interval])) by (le,queue)), \"quantile_filter\", \"p95\", \"\", \"\") and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p95\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p95 {{queue}}"
        },
        {
          "expr": "label_replace(histogram_quantile(0.50, sum(rate(celery_task_duration_seconds_bucket{}[$__rate_interval])) by (le,queue)), \"quantile_filter\", \"p50\", \"\", \"\") and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p50\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p50 {{queue}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["last", "max", "mean"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
