          "legendFormat": "p95 {{queue}}"
        },
        {
          "expr": "label_replace(histogram_quantile(0.50, sum(rate(face_detection_duration_seconds_bucket{}[$__rate_interval])) by (le,queue)), \"quantile_filter\", \"p50\", \"\", \"\") and on(quantile_filter) (label_replace(up, \"quantile_filter\", \"p50\", \"\", \"\") and on(quantile_filter) {quantile_filter=~\"$quantile\"})",
          "legendFormat": "p50 {{queue}}"
        }
