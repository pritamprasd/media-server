        },
        {
          "expr": "rate(files_deleted_total{}[$__rate_interval])",
          "legendFormat": "Deletes"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["last", "max", "mean"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": { "defaults": { "unit": "rps" } }
    },
    {
      "title": "File Serve / Download Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 69 },
      "targets": [
        {
          "expr": "rate(files_served_total{}[$__rate_interval])",
          "legendFormat": "Serves"
        },
        {
          "expr": "rate(files_downloaded_total{}[$__rate_interval])",
          "legendFormat": "Downloads"
        }
      ],
      "options": {
        "legend": {
