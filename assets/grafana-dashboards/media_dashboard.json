    {
      "title": "File Operations",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 68 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "File Import / Delete Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 69 },
